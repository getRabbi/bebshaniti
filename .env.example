# Copy to .env and replace placeholders. Never commit real credentials.
APP_ENV=local

# Supabase hosted project
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=replace-with-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-server-only-secret-key
SUPABASE_JWKS_URL=https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json
# Leave empty for projects using asymmetric JWT signing keys.
SUPABASE_JWT_SECRET=
SUPABASE_JWT_AUDIENCE=authenticated

# Database connections. Use the direct URL for migrations and the pooler at runtime.
SUPABASE_DIRECT_CONNECT=postgresql://postgres:replace-with-password@db.your-project-ref.supabase.co:5432/postgres
SUPABASE_SESSION_POOLER=postgresql://postgres.your-project-ref:replace-with-password@region.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres.your-project-ref:replace-with-password@region.pooler.supabase.com:5432/postgres

# Local and public application URLs
API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-publishable-or-anon-key
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_SITE_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CONTACT_EMAIL=hello@example.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
REDIS_URL=redis://localhost:6379/0

# Optional Vercel CLI identifiers
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
